{
  "name": "brush-nextjs-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm-release": "wasm-pack build .. --release --target bundler --out-dir web/pkg",
    "build:wasm-dev": "wasm-pack build .. --dev --target bundler --out-dir web/pkg",

    "dev": "npm run build:wasm-dev && next dev --turbopack --experimental-https",

    "build": "npm run build:wasm-release && cross-env NEXT_PUBLIC_BASE_PATH=/brush-demo next build --turbopack"
  },
  "dependencies": {
    "@types/three": "^0.175.0",
    "next": "^16.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "cross-env": "^7.0.3",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.4",
    "typescript": "^5.8.3"
  }
}
