{
  "goog:chromeOptions": {
    "args": [
      "--headless=new",

      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-gpu-sandbox",
      "--disable-dev-shm-usage",
      "--no-zygote",

      "--enable-unsafe-webgpu",
      "--enable-webgpu-developer-features",
      "--enable-dawn-features=allow_unsafe_apis,use_user_defined_labels_in_backend",

      "--enable-features=Vulkan",
      "--use-vulkan=native",
      "--enable-unsafe-swiftshader",

      "--enable-logging=stderr",
      "--v=1"
    ]
  }
}
